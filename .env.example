# Anthropic API Configuration
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Application Settings
LOG_LEVEL=INFO
MAX_RETRIES=3
TIMEOUT_SECONDS=120

# Template Configuration
TEMPLATE_LIBRARY_PATH=../02_POST_TEMPLATE_LIBRARY.md
CLIENT_BRIEF_TEMPLATE_PATH=../01_CLIENT_BRIEF_TEMPLATE.md
DELIVERABLE_TEMPLATE_PATH=../Jumpstart_Deliverable_Template.docx
DEFAULT_TEMPLATE_COUNT=15

# Output Settings
DEFAULT_OUTPUT_FORMAT=txt
DEFAULT_POST_COUNT=30

# Development Settings
DEBUG_MODE=false
CACHE_PROMPTS=true

# Database Configuration
POSTGRES_PASSWORD=  # REQUIRED: Use a strong password (min 16 chars, mixed case, numbers, symbols)
SECRET_KEY=  # REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Security - Admin User Authentication
# SECURITY FIX (TR-018): Set a strong password for admin users
# If not set, a random password will be generated on first startup
# IMPORTANT: Save the generated password immediately!
DEFAULT_USER_PASSWORD=  # REQUIRED: Set a strong password for admin users (min 12 chars)

# Admin User Configuration
# Option 1: Use default admin emails (mrskwiw@gmail.com, michele.vanhy@gmail.com)
# These will be created automatically with is_superuser=true

# Option 2: Override default admin emails
PRIMARY_ADMIN_EMAIL=mrskwiw@gmail.com
PRIMARY_ADMIN_NAME=Primary Admin
SECONDARY_ADMIN_EMAIL=michele.vanhy@gmail.com
SECONDARY_ADMIN_NAME=Secondary Admin

# Option 3: Configure multiple admin users explicitly
# ADMIN_USER_1_EMAIL=admin@example.com
# ADMIN_USER_1_NAME=Admin One
# ADMIN_USER_1_IS_SUPERUSER=true
# ADMIN_USER_2_EMAIL=operator@example.com
# ADMIN_USER_2_NAME=Operator Two
# ADMIN_USER_2_IS_SUPERUSER=false

# Force re-seed admin accounts (useful for password reset)
# Set to true, restart server, then set back to false
FORCE_ADMIN_SEED=false

# Super Admin Configuration (Task #51)
# Comma-separated list of email addresses for super admins (original system administrators)
# Only these users can grant free credits to users, even if other users are promoted to admin
# Example: "admin@example.com,owner@example.com"
# Leave empty to disable the grant credits feature
SUPER_ADMIN_EMAILS=mrskwiw@gmail.com,michele.vanhy@gmail.com
